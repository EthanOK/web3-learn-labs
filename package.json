{
  "name": "@ethanok/web3-learn-labs",
  "type": "module",
  "version": "0.0.3",
  "description": "A starter for creating a TypeScript package.",
  "author": "Author Name <author.name@mail.com>",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/EthanOK/web3-learn-labs.git"
  },
  "scripts": {
    "prettier": "bunx prettier --write \"{src,tests}/**/*.{js,ts,tsx,json,css,md}\"",
    "build": "bunx tsdown",
    "release": "bunx bumpp",
    "publish:sdk": "bun publish",
    "prepublishOnly": "bun run build",
    "avg-ticker": "bun run --watch utils/websocket/ticker/avg_ticker.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bumpp": "^11.0.1",
    "tsdown": "^0.21.7"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  }
}
